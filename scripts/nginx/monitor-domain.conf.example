# Шаблон nginx для домена дашборда (НЕ трогает courier / fuji-crm).
# Когда будет домен, на сервере:
#   sudo cp monitor-domain.conf /etc/nginx/sites-available/monitor.YOUR_DOMAIN
#   sudo ln -s /etc/nginx/sites-available/monitor.YOUR_DOMAIN /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#
# Замените YOUR_DOMAIN и при необходимости путь к сертификату (certbot).

upstream monitor_backend {
    server 127.0.0.1:3080;
}

server {
    listen 80;
    server_name YOUR_DOMAIN;

    location / {
        proxy_pass http://monitor_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection upgrade;
    }
}
