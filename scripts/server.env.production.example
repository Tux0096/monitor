# Production env lives ONLY on the server:
#   /opt/monitor/.env.local
#
# Do not copy this file to the server during deploy.
# Edit variables directly on the VM via SSH.

AUTH_SECRET=
AUTH_PASSWORD=
AUTH_URL=https://it.franchise-fuji.ru
AUTH_SERVICE_URL=http://127.0.0.1:3101
MONITOR_PORT=3080
MONITOR_DATABASE_URL=postgresql://monitor:CHANGE_ME@127.0.0.1:5433/monitor_core

FIREBASE_PROJECT_ID=fuji-notifications
BIGQUERY_LOCATION=US
GOOGLE_SERVICE_ACCOUNT_FILE=/opt/monitor/secrets/firebase-sa.json
GOOGLE_OAUTH_TOKEN_FILE=/opt/monitor/secrets/google-oauth.json
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

PERFORMANCE_IMPORT_SECRET=
