LOCAL_AI_URL=http://127.0.0.1:11434
LOCAL_AI_MODEL=qwen2.5:1.5b-instruct
LOCAL_AI_VISION_MODEL=moondream

MAX_BOT_TOKEN=
MAX_BOT_WEBHOOK_SECRET=
