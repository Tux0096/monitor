# Обязательно для NextAuth (сгенерируйте: openssl rand -base64 32)
AUTH_SECRET=

# Запасной вход без Google (только поле «Пароль» на экране входа)
AUTH_PASSWORD=

# OAuth веб-клиент Google Cloud (экран согласия + redirect URI)
# Redirect: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Проект Firebase для выгрузки (из консоли Firebase)
FIREBASE_PROJECT_ID=fuji-notifications

# Интервал проверки URL, мс
# CHECK_INTERVAL_MS=30000
